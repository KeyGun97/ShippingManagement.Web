@model List<ShippingManagement.Web.Models.User>
@{ ViewData["Title"] = "Users"; int myId = Context.Session.GetInt32("UserID") ?? 0; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-people"></i> User Management <span class="badge bg-dark">@Model.Count</span></h4>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Create User</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2"><label class="form-label small mb-0">Username</label>
                        <input name="username" class="form-control form-control-sm" required autocomplete="off" /></div>
                    <div class="mb-2"><label class="form-label small mb-0">Full name</label>
                        <input name="fullName" class="form-control form-control-sm" /></div>
                    <div class="mb-2"><label class="form-label small mb-0">Password</label>
                        <input name="password" type="password" class="form-control form-control-sm" required autocomplete="new-password" /></div>
                    <div class="mb-3"><label class="form-label small mb-0">Role</label>
                        <select name="role" class="form-select form-select-sm"><option>User</option><option>Admin</option></select></div>
                    <button class="btn btn-sm btn-success">Create User</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">All Users</div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light"><tr><th>Username</th><th>Full Name</th><th>Role</th><th>Status</th><th>Created</th><th style="width:300px"></th></tr></thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr class="@(u.IsActive ? "" : "text-muted")">
                                <td class="fw-semibold">@u.Username @(u.UserID == myId ? Html.Raw("<span class='badge bg-info'>you</span>") : Html.Raw(""))</td>
                                <td>@u.FullName</td>
                                <td><span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-secondary")">@u.Role</span></td>
                                <td>@(u.IsActive ? Html.Raw("<span class='badge bg-success'>Active</span>") : Html.Raw("<span class='badge bg-dark'>Inactive</span>"))</td>
                                <td class="small">@u.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (u.UserID != myId)
                                    {
                                        <form asp-action="ToggleActive" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.UserID" />
                                            <input type="hidden" name="active" value="@((!u.IsActive).ToString().ToLower())" />
                                            <button class="btn btn-sm py-0 @(u.IsActive ? "btn-outline-dark" : "btn-outline-success")">
                                                @(u.IsActive ? "Deactivate" : "Activate")</button>
                                        </form>
                                    }
                                    <form asp-action="ResetPassword" method="post" class="d-inline"
                                          onsubmit="var p = prompt('New password for @u.Username:'); if(!p) return false; this.newPassword.value = p; return true;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.UserID" />
                                        <input type="hidden" name="newPassword" value="" />
                                        <button class="btn btn-sm btn-outline-warning py-0">Reset Password</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
