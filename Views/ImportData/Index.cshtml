@model List<ShippingManagement.Web.Models.ScrapedRecord>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Af
@{
    ViewData["Title"] = "Import Data";
    var d = (DateTime)ViewBag.Date;
    string? country = ViewBag.Country;
    bool showUseless = ViewBag.ShowUseless, applyFilter = ViewBag.ApplyFilter;
    var countries = (List<ShippingManagement.Web.Models.CountryItem>)ViewBag.Countries;
    var importDates = (List<DateTime>)ViewBag.ImportDates;
    bool isAdmin = Context.Session.GetString("Role") == "Admin";
    var tokens = Af.GetAndStoreTokens(Context);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-cloud-download"></i> Import Data <span class="text-muted fs-6">@(isAdmin ? "(admin — all rows)" : "(your assigned ports only)")</span></h4>
    <div class="d-flex gap-2">
        @if (isAdmin)
        {
            @* "Fetch Data" moved next to the Filter button (see filter row below) *@
            @* <a asp-action="Upload" class="btn btn-sm btn-outline-primary"><i class="bi bi-upload"></i> Upload Rows</a> *@
            <form asp-controller="PortAssignments" asp-action="AutoData" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="importDate" value="@d.ToString("yyyy-MM-dd")" />
                <button class="btn btn-sm btn-warning"><i class="bi bi-lightning-charge"></i> Assign Data (@d.ToString("dd MMM"))</button>
            </form>
        }
        <form asp-action="SaveFiltered" method="post" class="d-inline" id="saveForm"
              onsubmit="return confirmSave();">
            @Html.AntiForgeryToken()
            <input type="hidden" name="date" value="@d.ToString("yyyy-MM-dd")" />
            <button class="btn btn-sm btn-success">
                <i class="bi bi-save"></i> Save Filtered to History
                <span class="badge text-bg-light ms-1 d-none" id="selCount"></span>
            </button>
        </form>
    </div>
</div>

<div class="d-flex flex-wrap align-items-end gap-2 mb-3">
    <form method="get" class="row g-2 align-items-end flex-grow-1">
        <div class="col-auto">
            <label class="form-label small mb-0">Import date</label>
            <input type="date" name="date" id="filterDate" value="@d.ToString("yyyy-MM-dd")" class="form-control form-control-sm" list="dates" />
            <datalist id="dates">@foreach (var id_ in importDates) {
            <option value="@id_.ToString("yyyy-MM-dd")"></option>
                        }
</datalist>
        </div>
        <div class="col-auto">
            <label class="form-label small mb-0">Country</label>
            <select name="country" id="filterCountry" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var c in countries)
                {
                    <option selected="@(country == c.CountryName)">@c.CountryName</option>
                }
            </select>
        </div>
        <div class="col-auto form-check ms-2">
            <input type="checkbox" class="form-check-input" name="applyFilter" value="true" id="af" checked="@applyFilter" />
            <label class="form-check-label small" for="af">Apply filter <em class="text-muted">(auto-excludes useless)</em></label>
        </div>
        <div class="col-auto form-check">
            <input type="checkbox" class="form-check-input" name="showUseless" value="true" id="su" checked="@showUseless" />
            <label class="form-check-label small" for="su">Show useless rows</label>
        </div>
        <div class="col-auto"><button class="btn btn-sm btn-primary">Filter</button></div>
    </form>

    @if (isAdmin)
    {
        <!-- V2 "Load Data": scrape all active Data Source URLs via Scripts/scraper.py and import the JSON -->
        <form asp-action="LoadData" method="post" id="loadDataForm" onsubmit="return startLoadData(this);">
            @Html.AntiForgeryToken()
            <input type="hidden" name="date" id="loadDate" value="@d.ToString("yyyy-MM-dd")" />
            <input type="hidden" id="loadCountry" name="country" value="@country" />
            <button class="btn btn-sm btn-info fw-semibold" id="loadDataBtn" type="submit"
                    title="Scrapes every active URL from Ports Setup → Data Sources and loads the results below">
                <i class="bi bi-globe"></i> Fetch Data
            </button>
        </form>
    }
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>Rows for @d.ToString("yyyy-MM-dd") — <span id="rowCount">@Model.Count</span> record(s)</span>
        <span class="small text-muted">Blue = regular customer &middot; Red strikethrough = useless &middot; double-click IMO cell to set/correct IMO</span>
    </div>
    <div class="table-responsive" style="max-height:65vh">
        <table class="table table-sm table-hover align-middle mb-0" id="importTable">
            <thead class="table-light sticky-top">
                <tr>
                    <th data-nosort style="width:28px"><input type="checkbox" class="form-check-input" id="selAll" title="Select / clear all rows on this page" /></th>
                    <th>Vessel</th>
                    <th>IMO</th>
                    <th>Port</th>
                    <th>Country</th>
                    <th>Arrival</th>
                    <th>Vessel Type</th>
                    <th>Origin</th>
                    @* <th>Status</th> *@
                    @if (isAdmin)
                    {
                        <th>Assigned To</th>
                    }
                    <th>Matched</th>
                    <th>Saved</th>
                    <th data-nosort style="width:50px">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr id="row-@r.ScrapeID" class="@(r.IsUseless ? "useless-row" : r.CustomerStatus == "Regular" ? "regular-customer" : "")">
                        <td data-sort="">
                            <input type="checkbox" class="form-check-input row-check" name="selectedIds"
                                   value="@r.ScrapeID" form="saveForm" @(r.IsUseless ? "disabled" : "") />
                        </td>
                        <td class="fw-semibold">@r.VesselName</td>
                        <td class="imo-cell" data-id="@r.ScrapeID" title="Double-click to set/correct IMO">
                            @if (r.IMO_Number is not null && @r.IsMatched == false)
                            {
                                <a asp-controller="Vessels" asp-action="Register"
                                   asp-route-imo="@r.IMO_Number"
                                   asp-route-name="@r.VesselName"
                                   asp-route-port="@r.PortName"
                                   asp-route-country="@r.Country"
                                   asp-route-vesselType="@r.VesselType"
                                   asp-route-origin="@r.Origin"
                                   title="Register this vessel — opens the form pre-filled (name, port, country, type, origin)">@r.IMO_Number</a>

                            }
                            else if (r.IMO_Number is not null && @r.IsMatched == true)
                            {
                                <a asp-controller="MasterData" asp-action="History"
                                   asp-route-imo="@r.IMO_Number">@r.IMO_Number</a>
                            }
                            else
                            {

                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@r.PortName</td>
                        <td>@r.Country</td>
                        <td class="small">@r.ArrivalDate</td>
                        <td class="small">@r.VesselType</td>
                        <td class="small">@r.Origin</td>
                        @* <td class="small">@r.VesselStatus</td> *@
                        @if (isAdmin)
                        {
                            <td class="small">@(r.AssignedUserName ?? "—")</td>
                        }
                        <td>@(r.IsMatched? Html.Raw("<span class='badge bg-success'>Yes</span>") : Html.Raw("<span class='badge bg-secondary'>No</span>"))</td>
                        <td>@(r.IsSaved? Html.Raw("<span class='badge bg-primary'>Saved</span>") : Html.Raw("<span class='badge bg-light text-dark border'>Pending</span>"))</td>
                        <td>
                            <button class="btn btn-sm py-0 useless-btn @(r.IsUseless ? "btn-danger" : "btn-outline-danger")"
                                    data-id="@r.ScrapeID" data-useless="@(r.IsUseless ? "true" : "false")">
                                @(r.IsUseless ? "Useless ✓" : "Useless")
                            </button>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="@(isAdmin ? 13 : 12)" class="text-center text-muted py-4">
                            No rows for this date. @(isAdmin ? "Upload rows, then run Auto Data to distribute them." : "Ask the admin to run Auto Data for your assigned ports.")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const af = '@tokens.RequestToken';

            // ---- row selection: select-all + live count on the Save button ----
            function refreshSelCount() {
                const n = $('.row-check:checked').length;
                $('#selCount').toggleClass('d-none', n === 0).text(n + ' selected');
            }
            $(document).on('change', '#selAll', function () {
                $('.row-check:not(:disabled)').prop('checked', this.checked);
                refreshSelCount();
            });
            $(document).on('change', '.row-check', refreshSelCount);

            function confirmSave() {
                const n = $('.row-check:checked').length;
                return n > 0
                    ? confirm('Save the ' + n + ' SELECTED row(s) of @d.ToString("yyyy-MM-dd") into the date-wise history?\n\n(Useless or IMO-less rows among them are skipped automatically.)')
                    : confirm('No rows are selected — save ALL your non-useless, IMO-matched rows of @d.ToString("yyyy-MM-dd") into the date-wise history?');
            }

                // "Load Data": confirm, then lock the button while the Python scraper runs on the server
                function startLoadData(form) {
                    // pull the CURRENT filter values (textbox date + country dropdown)
                    const selDate = (document.getElementById("filterDate") || {}).value || '';
                    const selCountry = (document.getElementById("filterCountry") || {}).value || '';

                    // push them into this form's hidden fields so the scrape uses them
                    document.getElementById("loadDate").value = selDate;
                    document.getElementById("loadCountry").value = selCountry;

                    if (!confirm("Load Data?"))
                        return false;

                    if (!confirm('Load Data will scrape ALL active source URLs from Ports Setup → Data Sources' +
                                 (selCountry ? ' (country: ' + selCountry + ')' : '') +
                                 ' for import date ' + selDate +
                                 '.\n\nThis can take several minutes. Continue?'))
                        return false;
                    const btn = document.getElementById('loadDataBtn');
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Scraping… please wait';
                    return true;
                }

                // V2 "Useless" button — real-time red highlight, no page reload, IMO added to global ignore list
                $(document).on('click', '.useless-btn', function () {
                    const btn = $(this), id = btn.data('id'), nowUseless = btn.attr('data-useless') !== 'true';
                    $.post('@Url.Action("MarkUseless")', { scrapeId: id, useless: nowUseless, __RequestVerificationToken: af })
                        .done(function () {
                            btn.attr('data-useless', nowUseless)
                               .toggleClass('btn-danger', nowUseless).toggleClass('btn-outline-danger', !nowUseless)
                               .text(nowUseless ? 'Useless ✓' : 'Useless');
                            $('#row-' + id).toggleClass('useless-row', nowUseless);
                        });
                });


        // V2 "Useless" button — real-time red highlight, no page reload, IMO added to global ignore list
        $(document).on('click', '.useless-btn', function () {
            const btn = $(this), id = btn.data('id'), nowUseless = btn.attr('data-useless') !== 'true';
            $.post('@Url.Action("MarkUseless")', { scrapeId: id, useless: nowUseless, __RequestVerificationToken: af })
                .done(function () {
                    btn.attr('data-useless', nowUseless)
                       .toggleClass('btn-danger', nowUseless).toggleClass('btn-outline-danger', !nowUseless)
                       .text(nowUseless ? 'Useless ✓' : 'Useless');
                    $('#row-' + id).toggleClass('useless-row', nowUseless);
                });
        });

        // Double-click vessel NAME → open the Vessel Registration form (prefilled), per spec.
        $(document).on('dblclick', '.vessel-name-cell', function () {
            const name = $(this).data('name');
            window.open('/Vessels/Register?name=' + encodeURIComponent(name || ''), '_blank');
        });

        // Double-click IMO cell → prompt & link the row to an IMO
        $(document).on('dblclick', '.imo-cell', function () {
            const id = $(this).data('id');
            const imo = prompt('Enter IMO number for this vessel:');
            if (!imo) return;
            $.post('@Url.Action("SetImo")', { scrapeId: id, imo: imo, __RequestVerificationToken: af })
                .done(r => r.ok ? location.reload() : alert(r.message));
        });
    </script>
}
