@model List<ShippingManagement.Web.Models.ArrivalLog>
@{
    string imo = ViewBag.Imo;
    var vessel = (ShippingManagement.Web.Models.Vessel?)ViewBag.Vessel;
    ViewData["Title"] = $"History — IMO {imo}";
    bool regular = vessel?.CustomerStatus == "Regular";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-clock-history"></i> IMO History — @imo
        @if (vessel is not null) { <span class="text-muted fs-6">@vessel.VesselName</span> }
        @if (regular) { <span class="badge bg-primary">Regular Customer</span> }
    </h4>
    <div>
        @if (vessel is not null)
        { <a class="btn btn-sm btn-outline-primary" asp-controller="Vessels" asp-action="Register" asp-route-imo="@imo">Open Vessel</a> }
        <a class="btn btn-sm btn-outline-dark" asp-action="Index">Back to Master Data</a>
    </div>
</div>

@if (vessel is not null)
{
    <div class="card mb-3 @(regular ? "border-primary" : "")">
        <div class="card-body small py-2">
            <div class="row">
                <div class="col-md-3"><strong>Type:</strong> @vessel.VesselType</div>
                <div class="col-md-3"><strong>Call Sign:</strong> @vessel.CallSign</div>
                <div class="col-md-3"><strong>Company:</strong> @vessel.CompanyName</div>
                <div class="col-md-3"><strong>Status:</strong> @vessel.Status</div>
            </div>
            <div class="row mt-1">
                <div class="col-md-4"><strong>Confirm:</strong> @vessel.ConfirmEmail</div>
                <div class="col-md-4"><strong>Purchase:</strong> @vessel.PurchaseEmail</div>
                <div class="col-md-4"><strong>Catering:</strong> @vessel.CateringEmail</div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning small">This IMO is not registered yet — <a asp-controller="Vessels" asp-action="Register" asp-route-imo="@imo">register it now</a>.</div>
}

<div class="card">
    <div class="card-header">Arrival History — @Model.Count visit(s)</div>
    <div class="table-responsive" style="max-height:60vh">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light sticky-top"><tr><th>#</th><th>Date</th><th>Port</th><th>Country</th><th>Tagged</th></tr></thead>
            <tbody>
                @{ int i = 1; }
                @foreach (var a in Model)
                {
                    <tr class="@(regular ? "regular-customer" : "")">
                        <td>@(i++)</td>
                        <td>@a.ArrivalDate.ToString("yyyy-MM-dd")</td>
                        <td>@a.PortName</td>
                        <td>@a.Country</td>
                        <td>@(a.IsTagged ? "Yes" : "No")</td>
                    </tr>
                }
                @if (Model.Count == 0) { <tr><td colspan="5" class="text-center text-muted py-3">No arrival history for this IMO yet.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
