@{ ViewData["Title"] = "Sign in"; Layout = "_Layout"; }

<div class="login-bg">

    <!-- Animated ambient particles -->
    <div class="login-particles" aria-hidden="true">
        @for (int i = 0; i < 14; i++) { <span></span> }
    </div>

    <div class="login-shell">

        <!-- ── Brand / story panel ── -->
        <div class="login-brand">
            <div class="radar" aria-hidden="true"></div>
            <div class="sonar" aria-hidden="true">
                <span class="ring"></span><span class="ring"></span><span class="ring"></span>
                <span class="core"></span>
            </div>

            <div class="brand-copy">
                <div class="eyebrow up-1">Port &amp; Fleet Operations</div>
                <h1 class="up-2">Shipping<br>Management System</h1>
                <p class="up-3">Track vessels, ports and daily arrivals from a single command console.</p>
                <ul class="login-feats up-4">
                    <li><i class="bi bi-water"></i> Vessel &amp; company registration</li>
                    <li><i class="bi bi-robot"></i> Automated port-data import</li>
                    <li><i class="bi bi-file-earmark-bar-graph"></i> Daily &amp; master reporting</li>
                </ul>
            </div>
        </div>

        <!-- ── Sign-in form ── -->
        <div class="login-form-panel">
            <div class="login-card card-body">
                <div class="text-center mb-4 up-1">
                    <div class="login-logo mb-3">
                        <svg class="logo-mark" viewBox="0 0 64 64" width="62" height="62" role="img" aria-label="Shipping Management System logo">
                            <defs>
                                <linearGradient id="lmGrad" x1="0" y1="0" x2="1" y2="1">
                                    <stop offset="0" stop-color="#2bb0fb" />
                                    <stop offset="1" stop-color="#1ad1a5" />
                                </linearGradient>
                                <radialGradient id="lmGloss" cx="34%" cy="28%" r="75%">
                                    <stop offset="0" stop-color="#ffffff" stop-opacity=".38" />
                                    <stop offset="1" stop-color="#ffffff" stop-opacity="0" />
                                </radialGradient>
                            </defs>
                            <circle cx="32" cy="32" r="30" fill="url(#lmGrad)" />
                            <circle cx="32" cy="32" r="30" fill="url(#lmGloss)" />
                            <circle cx="32" cy="32" r="27" fill="none" stroke="#ffffff" stroke-opacity=".25" stroke-width="1" />
                            <g class="helm">
                                <g fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round">
                                    <circle cx="32" cy="32" r="15.5" stroke-width="3.2" />
                                    <line x1="32" y1="10" x2="32" y2="54" />
                                    <line x1="10" y1="32" x2="54" y2="32" />
                                    <line x1="16.4" y1="16.4" x2="47.6" y2="47.6" />
                                    <line x1="47.6" y1="16.4" x2="16.4" y2="47.6" />
                                </g>
                                <g fill="#ffffff">
                                    <circle cx="54" cy="32" r="3" /><circle cx="47.6" cy="16.4" r="3" />
                                    <circle cx="32" cy="10" r="3" /><circle cx="16.4" cy="16.4" r="3" />
                                    <circle cx="10" cy="32" r="3" /><circle cx="16.4" cy="47.6" r="3" />
                                    <circle cx="32" cy="54" r="3" /><circle cx="47.6" cy="47.6" r="3" />
                                    <circle cx="32" cy="32" r="5.4" />
                                </g>
                            </g>
                            <circle cx="32" cy="32" r="2.3" fill="url(#lmGrad)" />
                        </svg>
                    </div>
                    <h4 class="mb-1">Welcome back</h4>
                    <small class="text-muted">Sign in to start your session</small>
                </div>

                @if (ViewBag.Error is string err)
                {
                    <div class="alert alert-danger py-2 d-flex align-items-center gap-2 mb-3 shake">
                        <i class="bi bi-exclamation-triangle-fill"></i><span>@err</span>
                    </div>
                }

                <form method="post" asp-action="Login" id="loginForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                    <div class="mb-3 up-2">
                        <label class="form-label">Username</label>
                        <div class="input-group login-ig">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input name="username" class="form-control"
                                   placeholder="Enter your username" autocomplete="username" autofocus required />
                        </div>
                    </div>

                    <div class="mb-2 up-3">
                        <label class="form-label">Password</label>
                        <div class="input-group login-ig">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input name="password" id="pwd" type="password" class="form-control"
                                   placeholder="Enter your password" autocomplete="current-password" required />
                            <span class="input-group-text toggle" id="togglePwd" role="button"
                                  tabindex="0" aria-label="Show password">
                                <i class="bi bi-eye" id="pwdIcon"></i>
                            </span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3 up-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="remember" name="remember" value="true">
                            <label class="form-check-label small text-muted" for="remember">Remember me</label>
                        </div>
                    </div>

                    <button class="btn btn-login w-100 up-4" id="loginBtn" type="submit">
                        <span class="btn-text"><i class="bi bi-box-arrow-in-right me-1"></i> Sign in</span>
                        <span class="btn-loading d-none">
                            <span class="spinner-border me-1" role="status"></span> Signing in…
                        </span>
                    </button>
                </form>

                <p class="text-center text-muted small mt-4 mb-0 up-4">
                    <i class="bi bi-shield-lock me-1"></i> Secured session · authorised users only
                </p>
            </div>
        </div>

    </div>

    <!-- Animated waves at the bottom -->
    <div class="login-waves" aria-hidden="true">
