@model List<ShippingManagement.Web.Models.PortSource>
@{
    var port = (ShippingManagement.Web.Models.Port)ViewBag.Port;
    ViewData["Title"] = $"Sources — {port.PortName}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-link-45deg"></i> Data Sources — @port.PortName <span class="text-muted fs-6">(@port.CountryName)</span></h4>
    <a asp-action="Index" asp-route-countryId="@port.CountryID" class="btn btn-sm btn-outline-dark">Back to Ports</a>
</div>

<div class="alert alert-light border small">
    A port can have <strong>multiple source URLs</strong>. Each source defines its own pagination:
    the <code>{page}</code> placeholder in the page-parameter pattern is replaced by the page number
    (e.g. <code>?page={page}</code> or <code>/p-{page}</code>). Pages are read from <em>Start Page</em> to <em>End Page</em>,
    capped at the port's Max Pages (currently <strong>@port.MaxPages</strong> — the "first 50 pages" rule by default).
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Add / Edit Source</div>
            <div class="card-body">
                <form asp-action="SaveSource" method="post" id="srcForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="SourceID" id="s_id" value="0" />
                    <input type="hidden" name="PortID" value="@port.PortID" />
                    <div class="mb-2"><label class="form-label small mb-0">Source name</label>
                        <input name="SourceName" id="s_name" class="form-control form-control-sm" placeholder="e.g. MyShipTracking" required /></div>
                    <div class="mb-2"><label class="form-label small mb-0">URL</label>
                        <input name="Url" id="s_url" class="form-control form-control-sm" placeholder="https://…" required /></div>
                    <div class="mb-2"><label class="form-label small mb-0">Page parameter pattern</label>
                        <input name="PageParamPattern" id="s_pat" class="form-control form-control-sm" placeholder="?page={page}" /></div>
                    <div class="row g-2 mb-2">
                        <div class="col"><label class="form-label small mb-0">Start page</label>
                            <input name="StartPage" id="s_start" type="number" min="1" value="1" class="form-control form-control-sm" /></div>
                        <div class="col"><label class="form-label small mb-0">End page</label>
                            <input name="EndPage" id="s_end" type="number" min="1" value="50" class="form-control form-control-sm" /></div>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="IsActive" id="s_active" value="true" checked />
                        <label class="form-check-label small" for="s_active">Active</label>
                    </div>
                    <button class="btn btn-sm btn-primary">Save Source</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetSrc()">Clear</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">Sources (@Model.Count)</div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light"><tr><th>Name</th><th>URL</th><th>Pattern</th><th>Pages</th><th>Active</th><th style="width:140px"></th></tr></thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr class="@(s.IsActive ? "" : "text-muted")">
                                <td>@s.SourceName</td>
                                <td class="small" style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><a href="@s.Url" target="_blank" rel="noopener">@s.Url</a></td>
                                <td><code class="small">@s.PageParamPattern</code></td>
                                <td>@s.StartPage–@s.EndPage</td>
                                <td>@(s.IsActive ? "Yes" : "No")</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary py-0"
                                            data-src='@System.Text.Json.JsonSerializer.Serialize(s)' onclick="editSrc(this)">Edit</button>
                                    <form asp-action="DeleteSource" method="post" class="d-inline" onsubmit="return confirm('Delete this source?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.SourceID" />
                                        <input type="hidden" name="portId" value="@port.PortID" />
                                        <button class="btn btn-sm btn-outline-danger py-0">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (Model.Count == 0) { <tr><td colspan="6" class="text-center text-muted py-3">No sources yet.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function editSrc(btn) {
        const s = JSON.parse(btn.dataset.src);
        $('#s_id').val(s.SourceID); $('#s_name').val(s.SourceName); $('#s_url').val(s.Url);
        $('#s_pat').val(s.PageParamPattern); $('#s_start').val(s.StartPage); $('#s_end').val(s.EndPage);
        $('#s_active').prop('checked', s.IsActive);
    }
    function resetSrc() { $('#s_id').val(0); $('#s_name,#s_url,#s_pat').val(''); $('#s_start').val(1); $('#s_end').val(50); $('#s_active').prop('checked', true); }
</script>
}
