@model List<ShippingManagement.Web.Models.Port>
@{
    ViewData["Title"] = "Ports Setup";
    var countries = (List<ShippingManagement.Web.Models.CountryItem>)ViewBag.Countries;
    int? countryId = ViewBag.CountryId;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-geo-alt"></i> Ports Setup <span class="text-muted fs-6">(Country → Port → Sources)</span></h4>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">1 — Add Country</div>
            <div class="card-body">
                <form asp-action="AddCountry" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <div class="col-7"><input name="countryName" class="form-control form-control-sm" placeholder="Country name" required /></div>
                    <div class="col-3 form-check d-flex align-items-center ms-2">
                        <input type="checkbox" class="form-check-input me-1" name="isAsia" value="true" id="isAsia" />
                        <label for="isAsia" class="form-check-label small">Asia</label>
                    </div>
                    <div class="col-1"><button class="btn btn-sm btn-success">Add</button></div>
                </form>
                <div class="form-text">The Asia flag drives the two-sheet (Asia / Non-Asia) Daily Report export.</div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">2 — Add / Edit Port</div>
            <div class="card-body">
                <form asp-action="SavePort" method="post" id="portForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PortID" id="p_id" value="0" />
                    <div class="mb-2">
                        <label class="form-label small mb-0">Country</label>
                        <select name="CountryID" id="p_country" class="form-select form-select-sm" required>
                            <option value="">— select —</option>
                            @foreach (var c in countries) { <option value="@c.CountryID" selected="@(countryId == c.CountryID)">@c.CountryName @(c.IsAsia ? "(Asia)" : "")</option> }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-0">Port name</label>
                        <input name="PortName" id="p_name" class="form-control form-control-sm" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-0">Max pages to read per source <em class="text-muted">(first-50-pages rule)</em></label>
                        <input name="MaxPages" id="p_max" type="number" min="1" max="500" value="50" class="form-control form-control-sm" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-0">Notes</label>
                        <input name="Notes" id="p_notes" class="form-control form-control-sm" />
                    </div>
                    <button class="btn btn-sm btn-primary">Save Port</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetPortForm()">Clear</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>3 — Ports @(Model.Count > 0 ? $"({Model.Count})" : "")</span>
                <form method="get" class="d-flex gap-2">
                    <select name="countryId" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All countries</option>
                        @foreach (var c in countries) { <option value="@c.CountryID" selected="@(countryId == c.CountryID)">@c.CountryName</option> }
                    </select>
                </form>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Port</th><th>Country</th><th>Max Pages</th><th>Sources</th><th>Assigned To</th><th style="width:200px"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@p.PortName</td>
                                <td>@p.CountryName</td>
                                <td>@p.MaxPages</td>
                                <td><span class="badge @(p.SourceCount > 0 ? "bg-info" : "bg-secondary")">@p.SourceCount URL(s)</span></td>
                                <td>@(p.AssignedUserName ?? "—")</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-info py-0" asp-action="Sources" asp-route-portId="@p.PortID">Sources</a>
                                    <button class="btn btn-sm btn-outline-primary py-0"
                                            onclick="editPort(@p.PortID, @p.CountryID, '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.PortName))'.slice(1,-1), @p.MaxPages, '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.Notes ?? ""))'.slice(1,-1))">Edit</button>
                                    <form asp-action="DeletePort" method="post" class="d-inline" onsubmit="return confirm('Delete port @p.PortName and its sources?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@p.PortID" />
                                        <input type="hidden" name="countryId" value="@countryId" />
                                        <button class="btn btn-sm btn-outline-danger py-0">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (Model.Count == 0) { <tr><td colspan="6" class="text-center text-muted py-3">No ports yet — add one on the left.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function editPort(id, countryId, name, maxPages, notes) {
        $('#p_id').val(id); $('#p_country').val(countryId); $('#p_name').val(name);
        $('#p_max').val(maxPages); $('#p_notes').val(notes);
        $('html,body').animate({ scrollTop: $('#portForm').offset().top - 80 }, 200);
    }
    function resetPortForm() { $('#p_id').val(0); $('#p_name,#p_notes').val(''); $('#p_max').val(50); }
</script>
}
