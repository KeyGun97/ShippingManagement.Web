<div class="card mb-3 no-print">
    <div class="card-body py-2">
        <form method="post" asp-action="Upload" enctype="multipart/form-data" class="row g-2 align-items-end">
            @Html.AntiForgeryToken()
            <input type="hidden" name="date" value="@d.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="country" value="@country" />
            <input type="hidden" name="category" value="@category" />
            <input type="hidden" name="regularOnly" value="@regularOnly.ToString().ToLower()" />
            <div class="col-auto">
                <label class="form-label small mb-0"><i class="bi bi-file-earmark-excel text-success"></i> Upload recipients from Excel</label>
                <input type="file" name="file" accept=".xlsx,.xlsm" class="form-control form-control-sm" required />
            </div>
            <div class="col-auto">
                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-upload"></i> Load from Excel</button>
            </div>
            <div class="col-12">
                <span class="form-text">
                    Matched columns: <code>Vessel Name</code>, <code>IMO</code>, <code>Company Name</code>,
                    <code>Confirm Email</code> (and Purchaser / Catering / Generated / General emails).
                    The <strong>Confirm Email</strong> column is used for the Confirm category.
                </span>
            </div>
        </form>
    </div>
</div>

@if (ViewBag.Uploaded == true)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center py-2 no-print">
        <span>
            <i class="bi bi-info-circle"></i>
            Showing <strong>@Model.Count</strong> recipient(s) uploaded from
            <strong>@ViewBag.UploadFile</strong> — database arrivals are hidden until you clear this list.
        </span>
        <form method="post" asp-action="ClearUpload" class="m-0">
            @Html.AntiForgeryToken()
            <input type="hidden" name="date" value="@d.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="country" value="@country" />
            <input type="hidden" name="category" value="@category" />
            <input type="hidden" name="regularOnly" value="@regularOnly.ToString().ToLower()" />
            <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-circle"></i> Clear list</button>
        </form>
    </div>

    <div class="alert alert-secondary py-2 small no-print mb-3">
        <i class="bi bi-diagram-3"></i> Uploaded list routing:
        <strong>Confirm Email → To</strong>,
        <strong>Call Sign → CC</strong>,
        <strong>Generated Email → BCC</strong>.
        Confirm Email is required for every recipient.
    </div>

    <div id="missingBanner" class="alert alert-danger py-2 no-print mb-3" style="@(missingConfirm > 0 ? "" : "display:none")">
        <i class="bi bi-exclamation-octagon"></i>
        <strong><span id="missingCount">@missingConfirm</span> recipient(s) have no To (Confirm) email.</strong>
        Confirm Email is used as the <em>To</em> address, so sending is blocked until every
        recipient has one. Fill the highlighted <em>To</em> cells in the table below — no need to re-upload.
    </div>
}

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Compose <span class="badge bg-primary ms-1">@category</span></span>
                <a asp-controller="EmailTemplates" asp-action="Index" class="small"><i class="bi bi-pencil-square"></i> Manage templates</a>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Send" id="sendForm"
                      data-uploaded="@uploaded.ToString().ToLower()"
                      data-missing-confirm="@missingConfirm"
                      data-send-count="@sendCount"
                      data-category="@category"
                      data-date="@d.ToString("yyyy-MM-dd")"
                      onsubmit="return confirmSend(this);">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="date" value="@d.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="country" value="@country" />
                    <input type="hidden" name="category" value="@category" />
                    <input type="hidden" name="regularOnly" value="@regularOnly.ToString().ToLower()" />

                    <div class="row g-2 mb-2">
                        <div class="col-sm-6">
                            <label class="form-label small mb-0">Send from</label>
                            <select name="profile" id="profileSelect" class="form-select form-select-sm">
                                @foreach (var p in profiles)
                                {
                                    <option value="@p.Name" selected="@(p.Name == defaultProfile)">
                                        @p.Name@(string.IsNullOrWhiteSpace(p.FromAddress) ? "" : $" — {p.FromAddress}")
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label small mb-0">Use template</label>
                            <select id="templateSelect" class="form-select form-select-sm">
                                <option value="">— none (manual) —</option>
                                @foreach (var t in templates)
                                {
                                    <option value="@t.TemplateID">@t.Name@(string.IsNullOrWhiteSpace(t.Category) ? "" : $" ({t.Category})")</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small mb-0">Subject</label>
                        <input name="subject" id="subjectInput" class="form-control form-control-sm" value="@ViewBag.DefaultSubject" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-0">Body</label>
                        <textarea name="body" id="bodyInput" class="form-control" rows="9" required>@ViewBag.DefaultBody</textarea>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="htmlBody" id="html" value="true" />
                        <label class="form-check-label small" for="html">Send as HTML</label>
                    </div>
                    <div class="form-text mb-2">
                        Placeholders: <code>{Vessel}</code> <code>{IMO}</code> <code>{Port}</code>
                        <code>{Country}</code> <code>{Company}</code> <code>{Date}</code>
                    </div>
                    <button id="sendBtn" class="btn btn-success @(sendCount == 0 ? "disabled" : "")">
                        <i class="bi bi-send"></i> Send to <span id="sendCount">@sendCount</span> recipient(s)
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                @if (uploaded)
                {
                    <span>Recipients — <strong>@toList.Count</strong> of @Model.Count have a Confirm (To) address</span>
                }
                else
                {
                    <span>Recipients — @withAddr.Count of @Model.Count arrival(s) have a @category address</span>
                }
                <span class="small text-muted">@d.ToString("dd MMM yyyy")</span>
            </div>
            <div class="table-responsive" style="max-height:100vh">
                <table class="table table-sm table-hover align-middle mb-0">
                    @if (uploaded)
                    {
                        <thead class="table-light sticky-top">
                            <tr>
                                <th>Vessel</th>
                                <th>IMO</th>
                                <th>Port</th>
                                <th>Company</th>
                                <th>To <span class="text-muted fw-normal">(Confirm)</span></th>
                                <th>CC <span class="text-muted fw-normal">(Call Sign)</span></th>
                                <th>BCC <span class="text-muted fw-normal">(Generated)</span></th>
                            </tr>
                        </thead>
                        <tbody id="recipRows">
                            @foreach (var a in Model)
                            {
                                bool noConfirm = string.IsNullOrWhiteSpace(a.ConfirmEmail);
                                <tr class="recip-row @(a.CustomerStatus == "Regular" ? "regular-customer" : "") @(noConfirm ? "table-danger" : "")">
                                    <td class="fw-semibold">@a.VesselName</td>
                                    <td>@a.IMO_Number</td>
                                    <td>@a.PortName</td>
                                    <td>@a.CompanyName</td>
                                    <td style="min-width:220px">
                                        <input form="sendForm" name="to" value="@a.ConfirmEmail"
                                               class="form-control form-control-sm to-input" placeholder="required — add To address"
                                               oninput="recalcRecipients()" />
                                    </td>
                                    <td style="min-width:200px">
                                        <input form="sendForm" name="cc" value="@a.CallSign"
                                               class="form-control form-control-sm" placeholder="optional" />
                                    </td>
                                    <td style="min-width:220px">
                                        <input form="sendForm" name="bcc" value="@a.GenerateEmail"
                                               class="form-control form-control-sm" placeholder="optional" />
                                    </td>
                                </tr>
                            }
                            @if (Model.Count == 0)
                            {
                                <tr><td colspan="7" class="text-center text-muted py-4">No recipients loaded. Upload an Excel list above.</td></tr>
                            }
                        </tbody>
                    }
                    else
                    {
                        <thead class="table-light sticky-top"><tr><th>Vessel</th><th>IMO</th><th>Port</th><th>Company</th><th>@category Email</th></tr></thead>
                        <tbody>
                            @foreach (var a in Model)
                            {
                                var addr = Addr(a);
                                <tr class="@(a.CustomerStatus == "Regular" ? "regular-customer" : "") @(string.IsNullOrWhiteSpace(addr) ? "text-muted" : "")">
                                    <td class="fw-semibold">@a.VesselName</td>
                                    <td>@a.IMO_Number</td>
                                    <td>@a.PortName</td>
                                    <td>@a.CompanyName</td>
                                    <td class="small">
                                        @if (string.IsNullOrWhiteSpace(addr))
                                        {
                                            <span class="text-danger">— none —</span>
                                        }
                                        else
                                        {

                                            @addr
                                        }
                                    </td>
                                </tr>
                            }
                            @if (Model.Count == 0)
                            {
                                <tr><td colspan="5" class="text-center text-muted py-4">No arrivals for this date/country. Generate a Daily Report first, or upload an Excel list above.</td></tr>
                            }
                        </tbody>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">Recent Email Activity <span class="text-muted small">(latest @log.Count)</span></div>
    <div class="table-responsive" style="max-height:40vh">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light sticky-top"><tr><th>When</th><th>Category</th><th>Via</th><th>To</th><th>Vessel</th><th>Subject</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var e in log)
                {
                    <tr>
                        <td class="small text-nowrap">@e.SentAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge bg-secondary">@e.Category</span></td>
                        <td class="small">@(string.IsNullOrWhiteSpace(e.SentVia) ? "—" : e.SentVia)</td>
                        <td class="small">@e.ToAddress</td>
                        <td class="small">@e.VesselName</td>
                        <td class="small">@e.Subject</td>
                        <td>
                            @if (e.Status == "Sent")
                            {
                                <span class="badge bg-success">Sent</span>
                            }
                            else if (e.Status == "Failed")
                            {

                                <span class="badge bg-danger" title="@e.ErrorText">Failed</span>
                            }
                            else
                            {

                                <span class="badge bg-info">Logged</span>
                            }
                        </td>
                    </tr>
                }
                @if (log.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No emails sent yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Recompute recipient count + missing-To highlight from the editable table cells.
        function recalcRecipients() {
            const rows = document.querySelectorAll('#recipRows .recip-row');
            if (!rows.length) return;
            let ok = 0, miss = 0;
            rows.forEach(function (r) {
                const to = r.querySelector('.to-input');
                const has = to && to.value.trim().length > 0;
                r.classList.toggle('table-danger', !has);
                has ? ok++ : miss++;
            });
            const cnt = document.getElementById('sendCount');
            if (cnt) cnt.textContent = ok;
            const btn = document.getElementById('sendBtn');
            if (btn) btn.classList.toggle('disabled', ok === 0);
            const banner = document.getElementById('missingBanner');
            const mc = document.getElementById('missingCount');
            if (mc) mc.textContent = miss;
            if (banner) banner.style.display = miss > 0 ? '' : 'none';
        }
        document.addEventListener('DOMContentLoaded', recalcRecipients);

        // Send-form guard: To (Confirm) is mandatory. Count live from the table so inline
        // edits are respected, and block the send if any To cell is empty.
        function confirmSend(form) {
            const uploaded = form.dataset.uploaded === 'true';
            const category = form.dataset.category || 'email';
            const date     = form.dataset.date || '';
            let count = parseInt(form.dataset.sendCount || '0', 10);

            if (uploaded) {
                const rows = document.querySelectorAll('#recipRows .recip-row');
                let miss = 0, ok = 0;
                rows.forEach(function (r) {
                    const to = r.querySelector('.to-input');
                    (to && to.value.trim()) ? ok++ : miss++;
                });
                if (miss > 0) {
                    alert('Cannot send: ' + miss + ' recipient(s) have no To (Confirm) email.\n\n' +
                          'Add a To address in the highlighted rows, then send.');
                    return false;
                }
                count = ok;
            }
            if (count === 0) { alert('There are no recipients with a valid To address.'); return false; }
            const routing = uploaded ? '\n(To = Confirm, CC = Call Sign, BCC = Generated)' : '';
            return confirm('Send the ' + category + ' email to ' + count +
                           ' recipient(s) for ' + date + '?' + routing);
        }

        // Templates supplied by the server (id -> subject/body/html). Picking one fills the form.
        const emailTemplates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    templates.ToDictionary(t => t.TemplateID, t => new { subject = t.Subject, body = t.Body, isHtml = t.IsHtml })));

    document.getElementById('templateSelect').addEventListener('change', function () {
        const t = emailTemplates[this.value];
        if (!t) return;
        document.getElementById('subjectInput').value = t.subject;
        document.getElementById('bodyInput').value = t.body;
        document.getElementById('html').checked = !!t.isHtml;
    });
</script>
}
