@{ ViewData["Title"] = "Dashboard"; bool isAdmin = Context.IsAdmin(); }

<div class="d-flex flex-wrap justify-content-between align-items-end mb-4 gap-2">
    <div>
        <h3 class="mb-1">Welcome, @Context.CurrentUserName()</h3>
        <p class="text-muted mb-0">Here's what's happening across your operation today.</p>
    </div>
    <span class="badge rounded-pill text-bg-light border px-3 py-2">
        <i class="bi bi-calendar3 me-1 text-primary"></i>@DateTime.Now.ToString("dddd, dd MMM yyyy")
    </span>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card tile p-3" style="background:linear-gradient(135deg,#143251,#0d2438)">
            <i class="bi bi-water position-absolute" style="right:16px;top:16px;font-size:1.4rem;opacity:.5"></i>
            <div class="display-6" data-count="@ViewBag.Vessels">0</div>
            <div class="tile-label">Registered Vessels</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card tile p-3" style="background:linear-gradient(135deg,#22a6f2,#1f7fd1)">
            <i class="bi bi-buildings position-absolute" style="right:16px;top:16px;font-size:1.4rem;opacity:.5"></i>
            <div class="display-6" data-count="@ViewBag.Companies">0</div>
            <div class="tile-label">Companies</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card tile p-3" style="background:linear-gradient(135deg,#1ad1a5,#12a884)">
            <i class="bi bi-star-fill position-absolute" style="right:16px;top:16px;font-size:1.4rem;opacity:.5"></i>
            <div class="display-6" @* data-count="@ViewBag.Regulars" *@>0</div>
            <div class="tile-label">Regular Customers</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card tile p-3" style="background:linear-gradient(135deg,#f6b441,#ef8f1f)">
            <i class="bi bi-box-arrow-in-down position-absolute" style="right:16px;top:16px;font-size:1.4rem;opacity:.5"></i>
            <div class="display-6" data-count="@ViewBag.TodayArrivals">0</div>
            <div class="tile-label">Today's Arrivals</div>
        </div>
    </div>
</div>

<h5 class="mb-3 text-muted"><i class="bi bi-grid me-1"></i>Modules</h5>
<div class="row g-3">
    @foreach (var (title, icon, url, desc) in new (string, string, string, string)[]
    {
        ("Vessel & Company Registration","bi-water","/Vessels","Register vessels by IMO, manage companies & fleets"),
        ("Import Data","bi-robot","/ImportData","Scraped port data, IMO matching, Useless handling, filtering"),
        ("Daily Report","bi-file-earmark-bar-graph","/DailyReport","Country/date report, single & Asia/Non-Asia exports"),
        @* ("Master Data","bi-database","/MasterData","Country-wise, company-wise & IMO history tracking"), *@
        @* ("Auto Emails","bi-envelope-paper","/AutoEmails","Send Confirm / Purchase / Catering & other emails to vessel contacts"), *@
        @* ("Regular Customers","bi-star-fill","/RegularCustomers","Dedicated dashboard for regular customers & their fleets"), *@
    })
    {
        <div class="col-md-6 col-xl-4">
            <a href="@url" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex gap-3">
                        <div class="flex-shrink-0 d-flex align-items-center justify-content-center"
                             style="width:46px;height:46px;border-radius:12px;background:rgba(34,166,242,.12)">
                            <i class="bi @icon text-primary" style="font-size:1.3rem"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-semibold text-dark">@title</h6>
                            <p class="text-muted small mb-0">@desc</p>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @* @if (isAdmin)
    {
        <div class="col-md-6 col-xl-4">
            <a href="/PortAssignments" class="text-decoration-none">
