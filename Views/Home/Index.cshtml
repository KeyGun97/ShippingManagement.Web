@{ ViewData["Title"] = "Dashboard"; bool isAdmin = Context.IsAdmin(); }
<h3 class="mb-1">Welcome, @Context.CurrentUserName()</h3>
<p class="text-muted">Front page — choose a module.</p>

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card tile p-3" style="background:#1b3a5c"><div class="display-6">@ViewBag.Vessels</div>Registered Vessels</div></div>
    <div class="col-md-3"><div class="card tile p-3" style="background:#22a6f2"><div class="display-6">@ViewBag.Companies</div>Companies</div></div>
    <div class="col-md-3"><div class="card tile p-3" style="background:#198754"><div class="display-6">@ViewBag.Regulars</div>Regular Customers</div></div>
    <div class="col-md-3"><div class="card tile p-3" style="background:#fd7e14"><div class="display-6">@ViewBag.TodayArrivals</div>Today's Arrivals</div></div>
</div>

<div class="row g-3">
    @foreach (var (title, icon, url, desc) in new (string, string, string, string)[]
    {
        ("Vessel & Company Registration","bi-water","/Vessels","Register vessels by IMO, manage companies & fleets"),
        ("Import Data","bi-robot","/ImportData","Scraped port data, IMO matching, Useless handling, filtering"),
        ("Daily Report","bi-file-earmark-bar-graph","/DailyReport","Country/date report, single & Asia/Non-Asia exports"),
        ("Master Data","bi-database","/MasterData","Country-wise, company-wise & IMO history tracking"),
        ("Regular Customers","bi-star-fill","/RegularCustomers","Dedicated dashboard for regular customers & their fleets"),
    })
    {
        <div class="col-md-4">
            <a href="@url" class="text-decoration-none">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5><i class="bi @icon text-primary me-2"></i>@title</h5>
                        <p class="text-muted small mb-0">@desc</p>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (isAdmin)
    {
        <div class="col-md-4">
            <a href="/PortAssignments" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-warning">
                    <div class="card-body">
                        <h5><i class="bi bi-diagram-3 text-warning me-2"></i>Port Assignment & Auto Data</h5>
                        <p class="text-muted small mb-0">Assign ports to users and distribute scraped data automatically</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>
