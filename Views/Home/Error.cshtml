@{ ViewData["Title"] = "Error"; }
<div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height:60vh">
    <div class="d-flex align-items-center justify-content-center mb-3"
         style="width:96px;height:96px;border-radius:28px;background:linear-gradient(135deg,#143251,#08182a);box-shadow:0 16px 36px rgba(8,24,42,.3)">
        <i class="bi bi-cone-striped text-white" style="font-size:2.6rem"></i>
    </div>
    <h3 class="mb-2">Something went wrong</h3>
    <p class="text-muted mb-4" style="max-width:44ch">An unexpected error occurred while handling your request. Please try again, or contact the administrator if it keeps happening.</p>
    <div class="d-flex gap-2">
        <a class="btn btn-primary px-4" href="/"><i class="bi bi-grid-1x2 me-1"></i> Back to dashboard</a>
        <a class="btn btn-outline-secondary px-4" href="javascript:history.back()">Go back</a>
    </div>
</div>
