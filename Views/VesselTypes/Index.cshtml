@model List<ShippingManagement.Web.Models.VesselType>
@{ ViewData["Title"] = "Vessel Types"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-tags"></i> Vessel Types <span class="badge bg-dark">@Model.Count</span></h4>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Add New Type</div>
            <div class="card-body">
                <form asp-action="Add" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input name="typeName" class="form-control form-control-sm" placeholder="e.g. LNG Tanker" required maxlength="100" />
                    <button class="btn btn-sm btn-success">Add</button>
                </form>
                <div class="form-text">The 36 standard types from the specification are pre-seeded by the database script.</div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">All Types</div>
            <div class="card-body p-2">
                <div class="row row-cols-2 row-cols-md-3 g-1">
                    @foreach (var t in Model)
                    {
                        <div class="col">
                            <div class="border rounded px-2 py-1 d-flex justify-content-between align-items-center small">
                                <span>@t.TypeName</span>
                                <form asp-action="Delete" method="post" onsubmit="return confirm('Delete type @t.TypeName?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.TypeID" />
                                    <button class="btn btn-sm btn-link text-danger p-0" title="Delete">&times;</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
