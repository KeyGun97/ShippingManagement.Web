@using ShippingManagement.Web.Infrastructure
@{
    var session = Context.Session;
    var fullName = session.GetString(SessionKeys.FullName);
    var role = session.GetString(SessionKeys.Role);
    bool isAdmin = role == "Admin";
    bool loggedIn = session.GetInt32(SessionKeys.UserID) is not null;
    string Active(string ctrl) => (ViewContext.RouteData.Values["controller"]?.ToString() == ctrl) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Shipping Management System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
@if (loggedIn)
{
    <nav class="navbar navbar-dark topbar px-3">
        <div class="d-flex align-items-center">
            <button class="nav-toggle" id="sidebarToggle" type="button" aria-label="Toggle menu">
                <i class="bi bi-list"></i>
            </button>
            <span class="navbar-brand fw-bold mb-0"><i class="bi bi-anchor me-2"></i>Shipping Management System</span>
        </div>
        <div class="d-flex align-items-center text-white gap-3">
            <span class="user-name"><i class="bi bi-person-circle me-1"></i>@fullName <span class="badge bg-info ms-1">@role</span></span>
            <span id="clock" class="small text-white-50 d-none d-md-inline"></span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-light"><i class="bi bi-box-arrow-right"></i> <span class="d-none d-sm-inline">Logout</span></button>
            </form>
        </div>
    </nav>

    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <div class="d-flex">
        <aside class="sidebar" id="sidebar">
            <a class="nav-link @Active("Home")" href="/"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            <a class="nav-link @Active("Vessels")" href="/Vessels"><i class="bi bi-water"></i> Vessel Registration</a>
            <a class="nav-link @Active("Companies")" href="/Companies"><i class="bi bi-buildings"></i> Companies</a>
            <a class="nav-link @Active("ImportData")" href="/ImportData"><i class="bi bi-robot"></i> Import Data</a>
            <a class="nav-link @Active("DailyReport")" href="/DailyReport"><i class="bi bi-file-earmark-bar-graph"></i> Daily Report</a>
            <a class="nav-link @Active("RegularCustomers")" href="/RegularCustomers"><i class="bi bi-star-fill"></i> Regular Customers</a>
            <a class="nav-link @Active("MasterData")" href="/MasterData"><i class="bi bi-database"></i> Master Data</a>
            <a class="nav-link @Active("AutoEmails")" href="/AutoEmails"><i class="bi bi-envelope-paper"></i> Auto Emails</a>
            <a class="nav-link @Active("EmailTemplates")" href="/EmailTemplates"><i class="bi bi-envelope-paper-heart"></i> Email Templates</a>
            @if (isAdmin)
            {
                <hr class="text-secondary my-2" />
                <div class="small text-uppercase text-secondary px-2 mb-1">Admin</div>
                <a class="nav-link @Active("PortsSetup")" href="/PortsSetup"><i class="bi bi-geo-alt"></i> Ports Setup</a>
                <a class="nav-link @Active("PortAssignments")" href="/PortAssignments"><i class="bi bi-diagram-3"></i> Port Assignments</a>
                <a class="nav-link @Active("VesselTypes")" href="/VesselTypes"><i class="bi bi-tags"></i> Vessel Types</a>
                <a class="nav-link @Active("Users")" href="/Users"><i class="bi bi-people"></i> Users</a>
            }
        </aside>
        <main class="flex-grow-1 p-4 content">
            @if (TempData["Ok"] is string ok)
            { <div class="alert alert-success alert-dismissible"><i class="bi bi-check-circle-fill me-1"></i>@ok<button class="btn-close" data-bs-dismiss="alert"></button></div> }
            @if (TempData["Error"] is string err)
            { <div class="alert alert-danger alert-dismissible"><i class="bi bi-exclamation-triangle-fill me-1"></i>@err<button class="btn-close" data-bs-dismiss="alert"></button></div> }
            @RenderBody()
        </main>
    </div>
}
else
{
    <main>@RenderBody()</main>
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="~/js/table-sort.js" asp-append-version="true"></script>
<script>
    // Live clock
    setInterval(() => { const c = document.getElementById('clock'); if (c) c.textContent = new Date().toLocaleString(); }, 1000);

    // Responsive sidebar (mobile)
    (function () {
        const sb = document.getElementById('sidebar');
        const bd = document.getElementById('sidebarBackdrop');
        const tg = document.getElementById('sidebarToggle');
        if (!sb || !tg) return;
        const open  = () => { sb.classList.add('show'); bd.classList.add('show'); };
        const close = () => { sb.classList.remove('show'); bd.classList.remove('show'); };
        tg.addEventListener('click', () => sb.classList.contains('show') ? close() : open());
        bd.addEventListener('click', close);
        sb.querySelectorAll('.nav-link').forEach(l => l.addEventListener('click', close));
    })();

    // Animated count-up for any element marked data-count
    (function () {
        document.querySelectorAll('[data-count]').forEach(el => {
            const target = parseInt(el.getAttribute('data-count'), 10) || 0;
            if (target <= 0) { el.textContent = target; return; }
            const dur = 900, start = performance.now();
            function tick(now) {
                const p = Math.min((now - start) / dur, 1);
                el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3)));
                if (p < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
        });
    })();

    // Staggered entrance for cards & accordion items (no-JS fallback: visible)
    (function () {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const els = document.querySelectorAll('.content > .card, .content .row > [class*="col"] > .card, .content .accordion-item, .content .tile');
        els.forEach((el, i) => { el.classList.add('rise-prep'); el.style.transitionDelay = Math.min(i, 10) * 55 + 'ms'; });
        requestAnimationFrame(() => requestAnimationFrame(() => {
            els.forEach(el => { el.classList.add('rise-go'); el.classList.remove('rise-prep'); });
        }));
    })();

    // Top navigation progress bar — gives a dynamic feel between pages
    (function () {
        const bar = document.createElement('div');
        bar.className = 'nav-progress';
        document.body.appendChild(bar);
        let timer;
        function start() {
            bar.classList.add('show'); bar.style.width = '8%';
            let w = 8;
            timer = setInterval(() => { w = Math.min(w + Math.random() * 12, 90); bar.style.width = w + '%'; }, 240);
        }
        function done() { clearInterval(timer); bar.style.width = '100%'; setTimeout(() => bar.classList.remove('show'), 300); }
        document.addEventListener('click', e => {
            const a = e.target.closest('a[href]');
            if (a && a.target !== '_blank' && !a.href.startsWith('javascript') && a.origin === location.origin) start();
        });
        document.addEventListener('submit', start, true);
        window.addEventListener('pageshow', done);
    })();

    // Global AJAX handler: session expiry on any component redirects to login.
    $(document).ajaxError(function (_e, xhr) {
        if (xhr.status === 401) window.location = '/Account/Login';
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
