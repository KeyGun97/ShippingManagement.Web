@{ ViewData["Title"] = "Access Denied"; }
<div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height:60vh">
    <div class="d-flex align-items-center justify-content-center mb-3"
         style="width:96px;height:96px;border-radius:28px;background:linear-gradient(135deg,#f4566d,#d63a52);box-shadow:0 16px 36px rgba(244,86,109,.35)">
        <i class="bi bi-shield-lock text-white" style="font-size:2.6rem"></i>
    </div>
    <h3 class="mb-2">Access denied</h3>
    <p class="text-muted mb-4" style="max-width:42ch">Your session doesn't have Administrator rights for this area. If you need access, ask an administrator to update your role.</p>
    <a class="btn btn-primary px-4" href="/"><i class="bi bi-grid-1x2 me-1"></i> Back to dashboard</a>
</div>
