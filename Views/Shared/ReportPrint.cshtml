@{
    Layout = null;
    var title = (string)(ViewBag.Title ?? "Report");
    var headers = (string[])(ViewBag.Headers ?? new string[0]);
    var rows = (List<string[]>)(ViewBag.Rows ?? new List<string[]>());
    var flags = ViewBag.RegularFlags as List<bool>;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@title</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; margin: 24px; color: #111; }
        .rpt-head { display:flex; align-items:center; gap:10px; border-bottom:3px solid #22a6f2; padding-bottom:8px; margin-bottom:12px; }
        .rpt-mark { width:34px; height:34px; border-radius:9px; background:linear-gradient(135deg,#22a6f2,#1ad1a5); color:#fff; display:flex; align-items:center; justify-content:center; font-size:18px; }
        h2 { margin: 0; color:#0d2438; } .sub { color:#555; margin-bottom:12px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #aab4c0; padding: 3px 5px; text-align: left; vertical-align: top; }
        th { background: #0d2438; color: #fff; }
        tr:nth-child(even) td { background:#f6f9fc; }
        tr.regular td { background: #d6ecff; }
        @@media print { .noprint { display: none; } }
    </style>
</head>
<body onload="window.print()">
    <div class="noprint" style="margin-bottom:10px">
        <button onclick="window.print()">Print / Save as PDF</button>
        <button onclick="window.close()">Close</button>
    </div>
    <div class="rpt-head">
        <div class="rpt-mark">&#9875;</div>
        <h2>@title</h2>
    </div>
    <div class="sub">@rows.Count record(s) &middot; Generated @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>
    <table>
        <thead>
            <tr>@foreach (var h in headers) { <th>@h</th> }</tr>
        </thead>
        <tbody>
            @for (int i = 0; i < rows.Count; i++)
            {
                var isReg = flags is not null && i < flags.Count && flags[i];
                <tr class="@(isReg ? "regular" : "")">
                    @foreach (var cell in rows[i]) { <td>@cell</td> }
                </tr>
            }
            @if (rows.Count == 0) { <tr><td colspan="@headers.Length" style="text-align:center;color:#888">No records.</td></tr> }
        </tbody>
    </table>
</body>
</html>
