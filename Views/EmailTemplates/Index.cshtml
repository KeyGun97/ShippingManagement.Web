@model List<ShippingManagement.Web.Models.EmailTemplate>
@{
    ViewData["Title"] = "Email Templates";
    var categories = (string[])ViewBag.Categories;
    var editing = ViewBag.Editing as ShippingManagement.Web.Models.EmailTemplate;
    bool isEdit = editing != null;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-envelope-paper-heart"></i> Email Templates <span class="badge bg-dark">@Model.Count</span></h4>
    <a asp-controller="AutoEmails" asp-action="Index" class="btn btn-sm btn-outline-primary"><i class="bi bi-envelope"></i> Go to Auto Emails</a>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">@(isEdit ? "Edit template" : "Add new template")</div>
            <div class="card-body">
                <form asp-action="Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="templateId" value="@(editing?.TemplateID ?? 0)" />

                    <div class="mb-2">
                        <label class="form-label small mb-0">Template name</label>
                        <input name="name" class="form-control form-control-sm" required maxlength="120"
                               placeholder="e.g. Catering enquiry — Asia" value="@(editing?.Name)" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-0">Category <em class="text-muted">(optional)</em></label>
                        <select name="category" class="form-select form-select-sm">
                            <option value="Any" selected="@(string.IsNullOrWhiteSpace(editing?.Category))">Any category</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c" selected="@(editing?.Category == c)">@c</option>
                            }
                        </select>
                        <div class="form-text">Tie a template to one category, or leave as "Any".</div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-0">Subject</label>
                        <input name="subject" class="form-control form-control-sm" required maxlength="300"
                               value="@(editing?.Subject ?? "{Vessel} (IMO {IMO}) arriving {Port}")" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-0">Body</label>
                        <textarea name="body" class="form-control" rows="9" required>@(editing?.Body ?? "Dear {Company},\n\nRegarding vessel {Vessel} (IMO {IMO}) arriving at {Port} on {Date}.\n\nRegards,\nOperations Team")</textarea>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" name="isHtml" value="true" id="isHtml" checked="@(editing?.IsHtml ?? false)" />
                        <label class="form-check-label small" for="isHtml">This template is HTML</label>
                    </div>
                    <div class="form-text mb-2">
                        Placeholders: <code>{Vessel}</code> <code>{IMO}</code> <code>{Port}</code>
                        <code>{Country}</code> <code>{Company}</code> <code>{Date}</code>
                    </div>
                    <button class="btn btn-sm btn-success"><i class="bi bi-save"></i> @(isEdit ? "Update" : "Add") template</button>
                    @if (isEdit)
                    {
                        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancel</a>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">Saved templates</div>
            <div class="table-responsive" style="max-height:70vh">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light sticky-top">
                        <tr><th>Name</th><th>Category</th><th>Subject</th><th>HTML</th><th class="text-end">Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@t.Name</td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(t.Category))
                                    { <span class="badge bg-light text-dark border">Any</span> }
                                    else { <span class="badge bg-secondary">@t.Category</span> }
                                </td>
                                <td class="small">@t.Subject</td>
                                <td>@(t.IsHtml ? "Yes" : "No")</td>
                                <td class="text-end text-nowrap">
                                    <a asp-action="Index" asp-route-edit="@t.TemplateID" class="btn btn-sm btn-outline-primary py-0"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete template &quot;@t.Name&quot;?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@t.TemplateID" />
                                        <button class="btn btn-sm btn-outline-danger py-0"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (Model.Count == 0)
                        { <tr><td colspan="5" class="text-center text-muted py-4">No templates yet. Add one on the left.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
